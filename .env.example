# MySQL bağlantısı (ör. mysql://kullanici:sifre@host:3306/veritabani)
DATABASE_URL=

# Oturum çerezlerini imzalamak için uzun ve rastgele bir gizli anahtar
JWT_SECRET=

# Panele giriş yapacak işletme sahibinin bilgileri
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAME=

# Trendyol sipariş entegrasyonu (Satıcı Paneli > Hesabım > Entegrasyon Bilgileri)
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=

# --- Opsiyonel: yalnızca Manus üzerinde çalışırken gerekli ---
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# AI özellikler (Pazarlama metni üretimi) — console.anthropic.com'dan alınır
ANTHROPIC_API_KEY=

# WhatsApp AI asistanı (kurulum: WHATSAPP.md)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ALLOWED_NUMBERS=
# Meta App Dashboard > Settings > Basic > App Secret; tanımlıysa gelen
# webhook'ların X-Hub-Signature-256 imzası doğrulanır (önerilir)
WHATSAPP_APP_SECRET=

# Render köprüsü (deploy tetikle/izle, log oku, env yönet) — kurulum: RENDER.md
# Render → Account Settings → API Keys → Create API Key
RENDER_API_KEY=
# Opsiyonel: servis kimliği/adı (verilmezse "artofcolour-kokpit" adından bulunur)
# RENDER_SERVICE_ID=
# RENDER_SERVICE_NAME=artofcolour-kokpit
