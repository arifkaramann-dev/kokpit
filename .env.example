# MySQL bağlantısı (ör. mysql://kullanici:sifre@host:3306/veritabani)
DATABASE_URL=

# Oturum çerezlerini imzalamak için uzun ve rastgele bir gizli anahtar
JWT_SECRET=

# Panele giriş yapacak işletme sahibinin bilgileri
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAME=

# Trendyol sipariş entegrasyonu (Satıcı Paneli > Hesabım > Entegrasyon Bilgileri)
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=

# Hepsiburada (Merchant paneli > Entegrasyon/OMS bilgileri)
HEPSIBURADA_MERCHANT_ID=
HEPSIBURADA_USERNAME=
HEPSIBURADA_PASSWORD=

# N11 (Satıcı paneli > Mağaza Ayarları > N11 API İşlemleri)
N11_APP_KEY=
N11_APP_SECRET=

# Çiçeksepeti Dükkan/Seller API (Panel > Entegrasyon > API Anahtarı)
CICEKSEPETI_API_KEY=

# --- Opsiyonel: yalnızca Manus üzerinde çalışırken gerekli ---
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# AI özellikler (Pazarlama metni üretimi) — console.anthropic.com'dan alınır
ANTHROPIC_API_KEY=

# e-Fatura / e-Arşiv entegratör bilgileri uygulama içinden (Ayarlar > e-Fatura)
# girilir; repoya/env'e yazılması zorunlu değildir. Entegratör: İzibiz/Uyumsoft/Foriba.
