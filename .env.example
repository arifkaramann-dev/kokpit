# MySQL bağlantısı (ör. mysql://kullanici:sifre@host:3306/veritabani)
DATABASE_URL=

# Oturum çerezlerini imzalamak için uzun ve rastgele bir gizli anahtar
JWT_SECRET=

# Panele giriş yapacak işletme sahibinin bilgileri
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAME=

# Trendyol sipariş entegrasyonu (Satıcı Paneli > Hesabım > Entegrasyon Bilgileri)
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=

# --- Opsiyonel: yalnızca Manus üzerinde çalışırken gerekli ---
# VITE_APP_ID=
# OAUTH_SERVER_URL=
# VITE_OAUTH_PORTAL_URL=
# OWNER_OPEN_ID=
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# AI özellikler (Pazarlama metni üretimi) — console.anthropic.com'dan alınır
ANTHROPIC_API_KEY=

# --- WhatsApp bağlı-cihaz köprüsü (opsiyonel) — kurulum: WHATSAPP.md ---
# "1" ise köprü başlar; kendine mesaj (note-to-self) sohbetine yazdığın komuttan
# taslak sipariş oluşturur. Boş/0 ise tamamen kapalı (varsayılan). Resmi olmayan
# istemci (Baileys); düşük de olsa ban riski vardır.
WHATSAPP_ENABLED=
# Oturum (giriş) durumunun saklandığı klasör. Kalıcı olması için Render'da disk
# bağla (yoksa her yeniden başlatmada QR'ı tekrar okutman gerekir). Varsayılan: .wa-auth
# WHATSAPP_AUTH_DIR=/data/wa-auth
# Kontrol sohbeti JID'i. Boş bırak → "kendine mesaj" (self-chat) kontrol yüzeyi olur.
# WHATSAPP_CONTROL_JID=

# Render köprüsü (deploy tetikle/izle, log oku, env yönet) — kurulum: RENDER.md
# Render → Account Settings → API Keys → Create API Key
RENDER_API_KEY=
# Opsiyonel: servis kimliği/adı (verilmezse "artofcolour-kokpit" adından bulunur)
# RENDER_SERVICE_ID=
# RENDER_SERVICE_NAME=artofcolour-kokpit
